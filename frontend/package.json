  "scripts": {
    "start:dev": "vite",
    "start:mock": "cross-env VITE_MOCK_MODE=true vite",
    "start:build": "NODE_ENV=production vue-tsc --noEmit && vite build",
    "cb": "vite build",
    "start:preview": "vite preview --port 3334",
    "serve": "NODE_ENV=production vue-tsc --noEmit && vite build && vite preview --port 3334",
    "serve:dev": "cross-env NODE_ENV=production DOMAIN_OVERRIDE=1 vue-tsc --noEmit && vite build && vite preview --port 3334",
    "typecheck": "vue-tsc --noEmit",
    "lint": "bun run lint:eslint && bun run lint:stylelint",
    "lint:eslint": "eslint . --ext .ts,.vue --cache",
    "lint:stylelint": "stylelint '**/*.css' --cache",
    "prettier": "prettier --check \"**/*.{ts,vue}\"",
    "prettier:write": "prettier --write \"**/*.{ts,vue}\""
  },
  "dependencies": {
    "@kastov/cryptohapp": "^1.1.2",
