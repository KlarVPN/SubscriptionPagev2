{
  "languages": {
    "JavaScript": {
      "formatter": {
        "external": {
          "command": "bunx",
          "arguments": ["prettier", "--stdin-filepath", "{buffer_path}"]
        }
      },
      "format_on_save": "on"
    },
    "TypeScript": {
      "formatter": {
        "external": {
          "command": "bunx",
          "arguments": ["prettier", "--stdin-filepath", "{buffer_path}"]
        }
      },
      "format_on_save": "on"
    },
    "Vue": {
      "formatter": {
        "external": {
          "command": "bunx",
          "arguments": ["prettier", "--stdin-filepath", "{buffer_path}"]
        }
      },
      "format_on_save": "on"
    }
  }
}
